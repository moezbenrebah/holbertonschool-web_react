describe('fetchNotifications', () => {
  test('sets loading state during fetch', () => {
    const pendingAction = fetchNotifications.pending();
    const state = notificationsSlice.reducer(undefined, pendingAction);
    expect(state.loading).toBe(true);
  });

  test('updates notifications on success', () => {
    const mockData = [{ id: 1, type: 'urgent' }];
    const fulfilledAction = fetchNotifications.fulfilled(mockData);
    const state = notificationsSlice.reducer(undefined, fulfilledAction);
    expect(state.notifications).toEqual(mockData);
    expect(state.loading).toBe(false);
  });
});
    
    
    
    


