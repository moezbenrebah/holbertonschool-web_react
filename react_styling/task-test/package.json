{
  "name": "travel-buddy",
  "version": "1.0.0",
  "description": "A travel buddy application connecting travelers with local guides",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev:server": "nodemon backend/server.js",
    "dev:client": "cd travel-buddy-frontend && npm start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "npm install && cd backend && npm install && cd ../travel-buddy-frontend && npm install",
    "build": "cd travel-buddy-frontend && npm run build",
    "test": "cd travel-buddy-frontend && npm test"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "mysql2": "^3.14.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
